# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Sesión ──────────────────────────────────────────────────
# Cambiá esto por una cadena aleatoria larga en producción
SESSION_SECRET=cambiar_por_string_aleatorio_seguro_32chars

# ─── Base de datos ───────────────────────────────────────────
# Para desarrollo local con SQLite, dejar DATABASE_URL vacío
# Para Railway/PostgreSQL, pegar la URL que provee Railway:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ─── WhatsApp ────────────────────────────────────────────────
# Carpeta donde se guarda la sesión de Baileys
WA_AUTH_PATH=./auth

# ─── App ─────────────────────────────────────────────────────
APP_NAME=Snow Motion CRM
APP_URL=http://localhost:3000
